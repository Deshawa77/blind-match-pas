@page
@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center py-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted">If an account exists for that email address, a password reset link has been generated and sent.</p>
                <a asp-page="./Login" class="btn btn-primary">Return to Login</a>
            </div>
        </div>
    </div>
</div>
