@page
@{
    ViewData["Title"] = "Password Updated";
}

<div class="row justify-content-center py-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted">Your password has been updated. You can sign in with the new password now.</p>
                <a asp-page="./Login" class="btn btn-primary">Go to Login</a>
            </div>
        </div>
    </div>
</div>
