@page
@model BlindMatchPAS.Areas.Identity.Pages.Account.Manage.EnableAuthenticatorModel
@{
    ViewData["Title"] = "Enable Authenticator";
}

<div class="row g-4 py-3">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted">Scan the secret below with an authenticator app, then enter the generated verification code to enable two-factor authentication.</p>

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="card bg-light border-0 mb-3">
                    <div class="card-body">
                        <div class="form-text text-uppercase mb-1">Manual setup key</div>
                        <code class="d-block">@Model.SharedKey</code>
                    </div>
                </div>

                <div class="card bg-light border-0 mb-4">
                    <div class="card-body">
                        <div class="form-text text-uppercase mb-1">Authenticator URI</div>
                        <code class="d-block text-break">@Model.AuthenticatorUri</code>
                    </div>
                </div>

                @if (Model.RecoveryCodes.Any())
                {
                    <div class="alert alert-success">
                        Two-factor authentication is enabled. Save these recovery codes in a secure place:
                    </div>
                    <div class="recovery-grid mb-4">
                        @foreach (var code in Model.RecoveryCodes)
                        {
                            <code>@code</code>
                        }
                    </div>
                }
                else
                {
                    <form method="post">
                        <div class="mb-3">
                            <label asp-for="Input.Code" class="form-label"></label>
                            <input asp-for="Input.Code" class="form-control" autocomplete="one-time-code" />
                            <span asp-validation-for="Input.Code" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Enable Two-Factor</button>
                        <a asp-page="./Security" class="btn btn-outline-secondary">Back to Security</a>
                    </form>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
