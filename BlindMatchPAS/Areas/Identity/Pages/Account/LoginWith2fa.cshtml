@page
@model BlindMatchPAS.Areas.Identity.Pages.Account.LoginWith2faModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
}

<div class="row justify-content-center py-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">@ViewData["Title"]</h1>
                <p class="text-muted">Enter the six-digit code from your authenticator application to complete sign-in.</p>

                <form method="post">
                    <input asp-for="RememberMe" type="hidden" />
                    <input asp-for="ReturnUrl" type="hidden" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Input.TwoFactorCode" class="form-label"></label>
                        <input asp-for="Input.TwoFactorCode" class="form-control" autocomplete="one-time-code" />
                        <span asp-validation-for="Input.TwoFactorCode" class="text-danger"></span>
                    </div>

                    <div class="form-check mb-3">
                        <input asp-for="Input.RememberMachine" class="form-check-input" />
                        <label asp-for="Input.RememberMachine" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary">Verify</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
