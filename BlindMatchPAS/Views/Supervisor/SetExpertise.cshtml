@model BlindMatchPAS.ViewModels.SupervisorExpertiseViewModel
@using BlindMatchPAS.Models

@{
    ViewData["Title"] = "Set Expertise";
    var researchAreas = ViewBag.ResearchAreas as List<ResearchArea>;
}

<h2>Set Preferred Research Areas</h2>

<form asp-action="SetExpertise" method="post">
    <div class="mb-3">
        @if (researchAreas != null)
        {
            foreach (var area in researchAreas)
            {
                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           name="SelectedResearchAreaIds"
                           value="@area.Id"
                    @(Model.SelectedResearchAreaIds.Contains(area.Id) ? "checked" : "") />
                    <label class="form-check-label">@area.Name</label>
                </div>
            }
        }
    </div>

    <button type="submit" class="btn btn-primary">Save Preferences</button>
    <a asp-action="BrowseProjects" class="btn btn-secondary">Back</a>
</form>