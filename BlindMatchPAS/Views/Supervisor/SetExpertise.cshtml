@model BlindMatchPAS.ViewModels.SupervisorExpertiseViewModel
@using BlindMatchPAS.Models

@{
    ViewData["Title"] = "Set Expertise";
    var researchAreas = ViewBag.ResearchAreas as List<ResearchArea>;
}

<section class="page-panel">
    <div class="section-header">
        <div>
            <div class="section-eyebrow">Expertise Alignment</div>
            <h1 class="h2 mt-2">Set Preferred Research Areas</h1>
            <p class="subtle-text mt-2">Choose the research areas that best reflect your supervision expertise. The blind review dashboard will prioritize proposals in these categories.</p>
        </div>
    </div>

    <form asp-action="SetExpertise" method="post" class="surface-card">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="info-chip-row mb-3">
            <span class="info-chip">Tip: select every area you are willing to supervise.</span>
        </div>
        <div class="mb-3">
            @if (researchAreas != null)
            {
                foreach (var area in researchAreas)
                {
                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="checkbox"
                               name="SelectedResearchAreaIds"
                               value="@area.Id"
                        @(Model.SelectedResearchAreaIds.Contains(area.Id) ? "checked" : "") />
                        <label class="form-check-label">@area.Name</label>
                    </div>
                }
            }
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save Preferences</button>
            <a asp-action="BrowseProjects" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</section>
