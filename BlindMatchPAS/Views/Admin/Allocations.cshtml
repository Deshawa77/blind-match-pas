@model IEnumerable<BlindMatchPAS.Models.MatchRecord>

@{
    ViewData["Title"] = "Allocations";
}

<section class="page-panel mb-4">
    <div class="section-header">
        <div>
            <div class="section-eyebrow">Allocation Oversight</div>
            <h1 class="h2 mt-2">All Allocations</h1>
            <p class="subtle-text mt-2">Review every confirmed blind match, verify the reveal trail, and intervene manually when reassignment is necessary.</p>
        </div>
    </div>
</section>

@if (!Model.Any())
{
    var emptyState = new BlindMatchPAS.ViewModels.EmptyStateViewModel
    {
        Title = "No confirmed allocations",
        Description = "Confirmed matches will appear here once supervisors finalize identity reveal."
    };
    <partial name="_EmptyState" model="emptyState" />
}
else
{
    <div class="table-shell">
        <table class="table align-middle">
            <thead>
                <tr>
                    <th>Project</th>
                    <th>Research Area</th>
                    <th>Student</th>
                    <th>Supervisor</th>
                    <th>Matched At</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var match in Model)
                {
                    <tr>
                        <td class="fw-semibold">@match.ProjectProposal?.Title</td>
                        <td>@match.ProjectProposal?.ResearchArea?.Name</td>
                        <td>
                            <div>@match.Student?.FullName</div>
                            <div class="subtle-text">@match.Student?.Email</div>
                        </td>
                        <td>
                            <div>@match.Supervisor?.FullName</div>
                            <div class="subtle-text">@match.Supervisor?.Email</div>
                        </td>
                        <td>@match.MatchedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <a asp-action="ReassignMatch" asp-route-id="@match.Id" class="btn btn-outline-primary btn-sm">Reassign</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
