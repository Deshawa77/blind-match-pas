@model BlindMatchPAS.ViewModels.AdminUserEditViewModel

@{
    ViewData["Title"] = "Edit User";
}

<section class="page-panel">
    <div class="section-header">
        <div>
            <div class="section-eyebrow">Identity Management</div>
            <h1 class="h2 mt-2">Edit User</h1>
            <p class="subtle-text mt-2">Update the user profile, selected role, and optional supervisor capacity override while keeping role metadata aligned.</p>
        </div>
    </div>

    <form asp-action="EditUser" method="post" class="surface-card">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="app-form-grid">
            <div>
                <label asp-for="FullName" class="form-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="UserName" class="form-label"></label>
                <input asp-for="UserName" class="form-control" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="SelectedRole" class="form-label"></label>
                <select asp-for="SelectedRole" asp-items="ViewBag.Roles" class="form-select">
                    <option value="">-- Select Role --</option>
                </select>
                <span asp-validation-for="SelectedRole" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="SupervisorCapacity" class="form-label"></label>
                <input asp-for="SupervisorCapacity" class="form-control" />
                <div class="form-text">Leave blank to fall back to the global default capacity.</div>
                <span asp-validation-for="SupervisorCapacity" class="text-danger"></span>
            </div>
        </div>

        <div class="d-flex flex-wrap gap-2 mt-4">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Users" class="btn btn-outline-secondary">Back</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
