@model IEnumerable<BlindMatchPAS.Models.ApplicationUser>

@{
    ViewData["Title"] = "Users";
}

<section class="page-panel mb-4">
    <div class="section-header">
        <div>
            <div class="section-eyebrow">Identity Management</div>
            <h1 class="h2 mt-2">Manage Users</h1>
            <p class="subtle-text mt-2">Provision platform accounts, manage role assignments, and set supervisor-specific capacity overrides where needed.</p>
        </div>
        <a asp-action="CreateUser" class="btn btn-primary">Create User</a>
    </div>
</section>

<div class="table-shell">
    <table class="table align-middle">
        <thead>
            <tr>
                <th>Full Name</th>
                <th>Email</th>
                <th>Username</th>
                <th>System Role</th>
                <th>Capacity</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.UserName</td>
                    <td><partial name="_StatusBadge" model="user.RoleType" /></td>
                    <td>@(user.SupervisorCapacity?.ToString() ?? "Default")</td>
                    <td>
                        <div class="d-flex flex-wrap gap-2">
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post">
                                <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Delete this user?');">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
