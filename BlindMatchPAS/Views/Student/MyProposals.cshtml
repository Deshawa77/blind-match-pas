@model IEnumerable<BlindMatchPAS.ViewModels.StudentProposalSummaryViewModel>

@{
    ViewData["Title"] = "My Proposals";
}

<section class="page-panel mb-4">
    <div class="section-header">
        <div>
            <div class="section-eyebrow">Proposal Portfolio</div>
            <h1 class="h2 mt-2">My Project Proposals</h1>
            <p class="subtle-text mt-2">Track blind matching, review timestamps, and see revealed supervisor details automatically after confirmation.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary">Submit New Proposal</a>
    </div>
</section>

@if (!Model.Any())
{
    var emptyState = new BlindMatchPAS.ViewModels.EmptyStateViewModel
    {
        Title = "No proposals submitted",
        Description = "The fastest way to get started is to submit one proposal with a strong abstract, technical stack, and research area.",
        ActionLabel = "Submit Proposal",
        ActionUrl = Url.Action("Create", "Student")
    };
    <partial name="_EmptyState" model="emptyState" />
}
else
{
    <div class="row g-4">
        @foreach (var proposal in Model)
        {
            <div class="col-xl-6">
                <div class="surface-card h-100">
                    <div class="section-header mb-3">
                        <div>
                            <h2 class="h5 mb-1">@proposal.Title</h2>
                            <div class="subtle-text">@proposal.ResearchAreaName</div>
                            <div class="subtle-text">@proposal.OwnershipLabel</div>
                        </div>
                        <partial name="_StatusBadge" model="proposal.Status" />
                    </div>

                    <div class="info-chip-row mb-3">
                        <span class="info-chip">Created @proposal.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                        @if (proposal.MatchedAt.HasValue)
                        {
                            <span class="info-chip">Matched @proposal.MatchedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                        }
                    </div>

                    <partial name="_ProposalTimeline" model="new BlindMatchPAS.ViewModels.ProposalTimelineViewModel { Status = proposal.Status, CreatedAt = proposal.CreatedAt, UpdatedAt = proposal.UpdatedAt, MatchedAt = proposal.MatchedAt, IsIdentityRevealed = proposal.IsIdentityRevealed }" />

                    <div class="mt-3">
                        <div class="subtle-text mb-1">Supervisor reveal</div>
                        @if (proposal.IsIdentityRevealed && !string.IsNullOrWhiteSpace(proposal.SupervisorFullName))
                        {
                            <div><strong>@proposal.SupervisorFullName</strong></div>
                            <div>@proposal.SupervisorEmail</div>
                        }
                        else
                        {
                            <div class="subtle-text">Hidden until match confirmation.</div>
                        }
                    </div>

                    <div class="d-flex flex-wrap gap-2 mt-4">
                        @if (proposal.CanEdit)
                        {
                            <a asp-action="Edit" asp-route-id="@proposal.Id" class="btn btn-outline-primary">Edit</a>
                        }

                        @if (proposal.CanWithdraw)
                        {
                            <form asp-action="Withdraw" asp-route-id="@proposal.Id" method="post">
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Are you sure you want to withdraw this proposal?');">
                                    Withdraw
                                </button>
                            </form>
                        }

                        @if (!proposal.CanEdit && !proposal.CanWithdraw)
                        {
                            <span class="subtle-text">This proposal is locked because the workflow has advanced.</span>
                        }

                        @if (proposal.IsGroupProposal && !proposal.CanManageOwnership)
                        {
                            <span class="subtle-text">You can view this group-owned proposal, but only the group lead can change it.</span>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
