@model ErrorViewModel
@{
    ViewData["Title"] = "Request Error";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h1 class="text-danger h3">Something went wrong</h1>
                <p class="text-muted mb-3">
                    BlindMatchPAS could not complete the requested operation. Please retry the action or contact the module leader if the issue continues.
                </p>

                @if (Model.ShowRequestId)
                {
                    <p class="mb-0">
                        <strong>Request ID:</strong> <code>@Model.RequestId</code>
                    </p>
                }
            </div>
        </div>
    </div>
</div>
